FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (10 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           nonuniform List<vector> 0();
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            noSlip;
    }
    drone
    {
        type            noSlip;
    }
    blades
    {
        type            movingWallVelocity;
        value           uniform (0 0 0);
    }
    procBoundary1to0
    {
        type            processor;
        value           uniform (10 0 0);
    }
    procBoundary1to2
    {
        type            processor;
        value           uniform (10 0 0);
    }
    procBoundary1to3
    {
        type            processor;
        value           uniform (10 0 0);
    }
    procBoundary1to4
    {
        type            processor;
        value           uniform (10 0 0);
    }
}


