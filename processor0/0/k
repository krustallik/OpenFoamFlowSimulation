FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.1;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           nonuniform List<scalar> 0();
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            kqRWallFunction;
        value           uniform 0.1;
    }
    drone
    {
        type            kqRWallFunction;
        value           nonuniform List<scalar> 0();
    }
    blades
    {
        type            kqRWallFunction;
        value           nonuniform List<scalar> 0();
    }
    procBoundary0to1
    {
        type            processor;
        value           uniform 0.1;
    }
    procBoundary0to2
    {
        type            processor;
        value           uniform 0.1;
    }
    procBoundary0to3
    {
        type            processor;
        value           uniform 0.1;
    }
}


