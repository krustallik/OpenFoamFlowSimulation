FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 10;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 10;
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            omegaWallFunction;
        value           uniform 10;
    }
    drone
    {
        type            omegaWallFunction;
        value           uniform 10;
    }
    blades
    {
        type            omegaWallFunction;
        value           uniform 10;
    }
    procBoundary3to0
    {
        type            processor;
        value           uniform 10;
    }
    procBoundary3to1
    {
        type            processor;
        value           uniform 10;
    }
    procBoundary3to2
    {
        type            processor;
        value           uniform 10;
    }
    procBoundary3to4
    {
        type            processor;
        value           uniform 10;
    }
    procBoundary3to5
    {
        type            processor;
        value           uniform 10;
    }
}


