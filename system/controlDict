FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     pimpleFoam;

startFrom       latestTime;
startTime       0;

stopAt          endTime;
//endTime         1;
endTime         0.1;
deltaT          0.001;

writeControl    timeStep;
writeInterval   10;

purgeWrite      0;

functions
{
    wallShearStress
    {
        type            wallShearStress;
        functionObjectLibs ("libfieldFunctionObjects.so");
        // Коли виводити результати: кожен часовий крок або за заданим інтервалом
        writeControl    timeStep;
        writeInterval   10;  // виводити кожні 50 кроків
      
        // Перелічіть патчі, для яких потрібно обчислювати wall shear stress
        patches         (drone blade1 blade2 blade3 blade4);
    }
}

