FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (10 0 0);  // 10 м/с по осі x

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (10 0 0);
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            noSlip;
    }
    drone
    {
        type            noSlip;
    }
    blades
    {
        type            movingWallVelocity;
        value           uniform (0 0 0);
    }
}