FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.1;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.1;
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            kqRWallFunction;
        value           uniform 0.1;
    }
    drone
    {
        type            kqRWallFunction;
        value           uniform 0.1;
    }
    blades
    {
        type            kqRWallFunction;
        value           uniform 0.1;
    }

